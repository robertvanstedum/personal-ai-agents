# minimoi — environment variables
# Copy to .env and fill in values before running docker-compose.
# On Mac (local dev) these are optional — apps fall back to macOS Keychain.
# On EC2 (production) these MUST be set. AWS Secrets Manager will inject them.

# ── LLM APIs ──────────────────────────────────────────────────────────────────
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # rvsopenbot (outbound delivery + CoS chat)
TELEGRAM_POLLING_BOT_TOKEN=   # minimoi_cmd_bot (German + Curator commands)
TELEGRAM_CHAT_ID=8379221762

# ── Translation ───────────────────────────────────────────────────────────────
DEEPL_API_KEY=

# ── Search ────────────────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ── Google OAuth (German Gespräche transcript sync) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=         # populated after first OAuth flow on Mac

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET=                 # generate with: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=simple123
POSTGRES_DB=personal_agents
NEO4J_AUTH=neo4j/simple123

# ── Portal ────────────────────────────────────────────────────────────────────
PORTAL_PORT=5001

# ── Gmail (Operations alert fallback) ────────────────────────────────────────
GMAIL_APP_PASSWORD=

# ── Whereby (German tutor session) ───────────────────────────────────────────
WHEREBY_HOST_URL=
WHEREBY_ROOM_URL=

# ── Legacy (keep for now) ─────────────────────────────────────────────────────
GEOPOLITICAL_FUTURES_USERNAME=
GEOPOLITICAL_FUTURES_PASSWORD=
