# minimoi EC2 environment — NON-SECRET config only.
# API keys are NOT here — they come from SSM Parameter Store automatically.
# Copy this to /opt/minimoi/.env on the EC2 instance.

# ── Ports ─────────────────────────────────────────────────────────────────────
PORTAL_PORT=5001

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_CHAT_ID=8379221702

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=simple123
POSTGRES_DB=personal_agents
DATABASE_URL=postgresql://minimoi:simple123@postgres:5432/personal_agents

# ── Whereby (fill in if using video sessions) ─────────────────────────────────
WHEREBY_HOST_URL=
WHEREBY_ROOM_URL=
