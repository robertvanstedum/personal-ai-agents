FROM python:3.12-slim

WORKDIR /app

COPY docker/requirements.cos-agent.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY core/ core/
COPY utils/ utils/
COPY domains/guild/ domains/guild/
COPY domains/cos/ domains/cos/
COPY telegram_cos_bot.py .

CMD ["python", "telegram_cos_bot.py"]
