# /opt/minimoi/.env.cos — CoS container credential file
# Least-privilege: Grok API key + minimoi_cos_bot token + guild-schema Postgres only.
# Values come from SSM where available; set on host, never committed to git.

# Grok API (xAI)
XAI_API_KEY=

# Telegram bot token for minimoi_cos_bot (production) / minimoi_cos_test_bot (standby)
TELEGRAM_COS_BOT_TOKEN=

# PostgreSQL — guild schema only (cos_agenda, guest_requests, design_log)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://minimoi:simple123@localhost:5432/personal_agents

# Role: "production" (minimoi_cos_bot) or "standby" (minimoi_cos_test_bot)
MINIMOI_ROLE=production

# Chat ID for Telegram notifications (Robert's chat)
TELEGRAM_CHAT_ID=8379221702

# Port for the Flask service
PORT=8769

# Set to 1 when cos-bot container handles Telegram polling (split container setup)
DISABLE_TELEGRAM_POLL=1
